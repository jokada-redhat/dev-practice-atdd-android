<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Success Icon -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="24dp"
            android:src="@android:drawable/ic_menu_send"
            android:tint="@color/primary"
            android:contentDescription="@string/loan_confirmed_title" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/loan_confirmed_heading"
            android:textSize="28sp"
            android:textColor="@color/on_surface"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/loan_confirmed_subtitle"
            android:textSize="16sp"
            android:textColor="@color/on_surface_variant"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="32dp" />

        <!-- Loan Summary Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/surface_container_lowest"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/loan_summary"
                    android:textSize="11sp"
                    android:textColor="@color/on_surface_variant"
                    android:textAllCaps="true"
                    android:letterSpacing="0.15"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Book Info -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/borrowed_artifact"
                    android:textSize="10sp"
                    android:textColor="@color/outline"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textConfirmBookTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textColor="@color/on_surface"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/textConfirmBookAuthor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface_variant"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="20dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/surface_container_high"
                    android:layout_marginBottom="20dp" />

                <!-- Member Info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/borrower_label"
                            android:textSize="10sp"
                            android:textColor="@color/outline"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textConfirmMemberName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="@color/on_surface"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:id="@+id/textConfirmMemberId"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="@color/on_surface_variant" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/return_due_date"
                            android:textSize="10sp"
                            android:textColor="@color/outline"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textConfirmDueDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="@color/on_surface"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/loan_duration"
                            android:textSize="12sp"
                            android:textColor="@color/on_surface_variant" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Auto redirect message -->
        <TextView
            android:id="@+id/textAutoRedirect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_redirect_message"
            android:textSize="12sp"
            android:textColor="@color/on_surface_variant"
            android:layout_marginBottom="16dp" />

        <!-- Home Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonGoHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/go_home_button"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="24dp"
            app:backgroundTint="@color/primary" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
